#!/usr/bin/env bash
# SessionStart hook for om-claude-plugin
# Detects OM projects and injects available skills context

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Detect OM project — check working directory for OM indicators
is_om_project=false

if [ -f "package.json" ] && grep -q "@open-mercato/" package.json 2>/dev/null; then
  is_om_project=true
elif [ -f "AGENTS.md" ] && grep -q "Open Mercato" AGENTS.md 2>/dev/null; then
  is_om_project=true
elif [ -d ".ai" ]; then
  is_om_project=true
elif [ -d "app-spec" ]; then
  is_om_project=true
fi

# If not an OM project, exit silently
if [ "$is_om_project" = false ]; then
  echo '{}'
  exit 0
fi

# Detect OM vanilla (path-based skill mandates are present alongside the plugin).
# When .ai/skills/ exists, AGENTS.md likely routes tasks to .ai/skills/<name>/SKILL.md
# entries — those mandates duplicate plugin om-* descriptions for synced skills.
# The hybrid routing block below tells the agent how to resolve precedence.
is_om_vanilla=false
if [ -d ".ai/skills" ]; then
  is_om_vanilla=true
fi

# Build context message
read -r -d '' OM_CONTEXT << 'CTXEOF' || true
You are working in an Open Mercato project with OM Superpowers active.

## IMPORTANT: Session Start Behavior — Enforce the Process

When the session starts, briefly greet the user and announce that OM Superpowers are active. Then **detect where they are in the pipeline** and guide them to the correct next step. Do NOT present a menu of options — the process is sequential, not pick-any.

### The Pipeline (enforced order)

1. **om-product-manager (Mat)** → App Spec (brainstorm, workflows, user stories, platform mapping)
2. **om-cto (Piotr) Spec Orchestrator** → decomposes App Spec into functional specs + execution plan
3. **User reviews & approves specs**
4. **om-cto (Piotr) Implementation Orchestrator** → dispatches om-implement-spec per spec, checkpoints between specs
5. **om-implement-spec** → code + unit tests + integration tests + docs → auto-invokes om-code-review
6. **om-code-review** → CI/CD gate → merge

### How to detect where the user is

- **No App Spec exists for the feature** → Start at step 1 (om-product-manager)
- **App Spec exists but no functional specs** → Start at step 2 (om-cto Spec Orchestrator)
- **Functional specs exist but not approved** → Ask user to review & approve
- **Approved specs exist, not yet implemented** → Start at step 4 (om-cto Implementation Orchestrator)
- **Implementation in progress** → Resume at the current spec/phase
- **Implementation done, no code review** → Run om-code-review

### Standalone skills (can be used anytime, outside the pipeline)

These do NOT skip the pipeline — they are support tools:
- **om-cto Advisory mode** — "does OM already do X?", architecture questions, gap analysis
- **om-troubleshooter** — diagnose errors, 404s, migration issues
- **om-ux (Krug)** — UI architecture review (also invoked during Mat's §3.5)
- **om-system-extension** — extend core modules via UMES (enrichers, widgets, interceptors)
- **om-data-model-design** — entity design, relationships, migration lifecycle
- **om-backend-ui-design** — backend UI pages within OM component library
- **om-eject-and-customize** — safe module ejection when UMES isn't enough
- **om-integration-tests** — run existing test suites
- **om-code-review** — review a PR or diff (standalone)
- **om-toolkit-review** — audit skill corpus for context waste and structural issues

### Rules

- If the user asks to "build X" or "add feature X", ALWAYS start at step 1 (om-product-manager). No shortcuts.
- If the user asks to "implement spec X", verify the spec is approved before proceeding.
- Never offer implementation as an option when specs don't exist yet.
- Tell the user where they are and what the next step is. Guide, don't ask.

### User Proxy

After greeting and pipeline guidance, check for the user proxy:

- If `app-spec/proxy-lessons.md` exists in the working directory → proxy is set up. Read the file for the proxy name and lesson count. Announce: "[Name] is active. [N] app lessons, [M] global lessons."
- If no proxy-lessons.md exists → introduce the proxy concept and ask the user to name them. See the `om-user-proxy` skill for the full onboarding flow.

The proxy is invoked by other skills before presenting questions to the user. You do not need to invoke it during session-start — it activates when skills call it.

## Available OM Skills

**Spec & Design:**
- om-product-manager: Product owner workflow — business context, workflows, user stories, platform mapping
- om-cto: CTO challenge — gap analysis, "does OM already do X?", atomic commit estimation
- om-ux: UI architecture review — navigation, task completion, cognitive load
- om-spec-writing: Specification creation with architectural compliance

**Implementation:**
- om-implement-spec: Multi-phase spec implementation with coordinated subagents
- om-pre-implement-spec: Pre-implementation BC impact and risk analysis
- om-module-scaffold: Bootstrap a new module from scratch (entities, API, pages, ACL, events)
- om-data-model-design: Entity design, relationships, migrations, MikroORM patterns
- om-system-extension: UMES extensions — enrichers, widgets, interceptors, guards, component replacement
- om-eject-and-customize: Safe module ejection when UMES isn't enough
- om-integration-builder: Provider package development (payment, shipping, data sync)
- om-backend-ui-design: Backend UI patterns within OM framework

**Testing & Quality:**
- om-code-review: CI/CD verification gate + full OM checklist (20+ sections)
- om-integration-tests: Playwright integration test creation and execution
- om-troubleshooter: Diagnose and fix common OM issues (errors, 404s, migrations, widgets)
- om-toolkit-review: Audit skill corpus for context waste, duplication, and structural issues

**Pipeline:**
- om-user-proxy: User's decision proxy — intercepts questions, resolves from context, escalates only business judgment calls

## Rules

- ALWAYS prefer om-* skills over generic equivalents when working on OM code.
- Once a skill workflow is started, follow it to completion — do not break out or skip steps.
- Do not wait for the user to say "use superpowers" or "follow om skills" — they are always on.
CTXEOF

# Hybrid routing — only when OM vanilla is detected (path mandates + plugin both present).
# This block is the soft-enforcement layer addressed in
# docs/specs/2026-05-06-ralph-loop-baseline.md's follow-on discussion: it reduces
# duplicate execution between AGENTS.md path mandates and plugin description-match,
# but does NOT eliminate it. Measure double-fire rate after rollout to validate.
#
# MAINTENANCE: the custom-skill list below is hard-coded. If
# scripts/sync-om-skills.sh changes which skills are synced vs custom,
# update the list here too.
if [ "$is_om_vanilla" = true ]; then
  read -r -d '' HYBRID_ROUTING << 'HYBEOF' || true


## OM Vanilla Hybrid — Routing Precedence

This project has `.ai/skills/` (path-based mandates from AGENTS.md) AND the om-superpowers plugin loaded. Both surfaces overlap for synced skills. To avoid duplicate execution and version drift:

| Source | Authoritative for the matching task? |
|---|---|
| AGENTS.md row → `.ai/skills/<name>/SKILL.md` | **YES** — always honor first |
| Plugin om-`<name>` Skill (synced from upstream) | NO — same content as path; cross-reference only |
| Plugin om-cto / om-product-manager / om-ux / om-user-proxy | YES — custom in this repo, no `.ai/skills/` counterpart |
| Plugin om-auto-create-pr / om-auto-continue-pr | YES — forked in v1.10.0 (tests-with-code gate), ahead of upstream |

### Rules

- If you read `.ai/skills/<name>/SKILL.md` due to an AGENTS.md mandate, do NOT additionally fire the matching plugin om-`<name>` Skill — they have identical content; you would double-load.
- The 6 custom/forked skills above are PRIMARY because they have no `.ai/skills/` counterpart or are ahead of upstream. Always invoke them via the Skill tool, regardless of any AGENTS.md content.
- Subagents dispatched during this session may not inherit this routing context. If you orchestrate subagents (Agent tool), include the relevant precedence inline in the subagent prompt when it touches an om-* skill area.

### Caveat

This is a soft routing rule (context note), not harness enforcement. Description-match still fires the plugin Skill if the model judges the description hits the prompt. The rule reduces duplicate execution but does not eliminate it.
HYBEOF

  OM_CONTEXT="${OM_CONTEXT}${HYBRID_ROUTING}"
fi

# Escape for JSON
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

escaped_context=$(escape_for_json "$OM_CONTEXT")

# Output for Claude Code or Cursor
if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "additional_context": "%s"\n}\n' "$escaped_context"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$escaped_context"
else
  printf '{\n  "additional_context": "%s"\n}\n' "$escaped_context"
fi

exit 0
